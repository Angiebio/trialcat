# trialcat environment configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# =============================================================================
# APP CONFIG
# =============================================================================
APP_NAME=trialcat
APP_ENV=development              # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# =============================================================================
# DATABASE
# =============================================================================
# SQLite for MVP. Upgrade to Postgres URL in production if needed.
DATABASE_URL=sqlite:///data/trialcat.db

# =============================================================================
# CLINICALTRIALS.GOV API
# =============================================================================
# No API key required - public endpoint. Base URL only.
CTGOV_API_BASE=https://clinicaltrials.gov/api/v2
CTGOV_USER_AGENT=trialcat/0.1 (https://trialcat.ai; contact@therealcat.ai)
CTGOV_FETCH_PAGE_SIZE=100

# =============================================================================
# AI SERVICES (for NL features, Phase 7+)
# =============================================================================
# OpenAI - used for embeddings and NL analysis
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# RATE LIMITING
# =============================================================================
# Detailed stats (per-month breakdowns) limited per IP per day
RATE_LIMIT_DETAIL_PER_DAY=1
# Basic stats (totals) - more generous
RATE_LIMIT_BASIC_PER_HOUR=60

# =============================================================================
# MONETIZATION / MAILING LIST
# =============================================================================
# Ko-fi donation link (just a URL, no API)
KOFI_URL=https://ko-fi.com/therealcatai

# Buttondown mailing list
BUTTONDOWN_API_KEY=
BUTTONDOWN_NEWSLETTER=trialcat

# =============================================================================
# OBSERVABILITY
# =============================================================================
# Sentry error tracking (optional, free tier)
SENTRY_DSN=

# =============================================================================
# FUTURE: AI WORKERS (v2)
# =============================================================================
# RunPod Serverless endpoint for self-hosted models
RUNPOD_ENDPOINT_URL=
RUNPOD_API_KEY=
